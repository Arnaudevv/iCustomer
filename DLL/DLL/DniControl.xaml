<UserControl x:Class="DLL.DniControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DLL"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <Border x:Name="textBoxBorder" BorderBrush="#30363D" BorderThickness="1">
            <TextBox x:Name="TextBox"
                Text="{Binding CustomerDni, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"                    
                Background="{Binding TextBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Foreground="{Binding TextForeground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Padding="{Binding TextPadding, RelativeSource={RelativeSource AncestorType=UserControl}}"
                FontFamily="{Binding TextFontFamily, RelativeSource={RelativeSource AncestorType=UserControl}}"
                FontSize="{Binding TextFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CaretBrush="{Binding TextCaretBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                SelectionBrush="{Binding TextSelectionBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                BorderThickness="0"
                TextChanged="DniControl_PreviewTextChange"/>
        </Border>
        <TextBlock Name="warningText" />
    </StackPanel>
</UserControl>
