<Window x:Class="TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DLL"
        Title="Test NameControl" Height="300" Width="500" WindowStartupLocation="CenterScreen">
    <Grid Background="#F0F0F0">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <TextBlock Text="Prueba NameControl" FontSize="20" FontWeight="Bold" Foreground="#333"/>
            
            <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="20" CornerRadius="5">
                <StackPanel Spacing="15">
                    <TextBlock Text="Ingresa un nombre (mínimo 3 caracteres):" FontSize="12" Foreground="#666"/>
                    <local:NameControl x:Name="NameControl" MinLength="3" Height="40"/>
                    
                    <TextBlock Text="Características:" FontSize="11" FontWeight="Bold" Foreground="#666" Margin="0,10,0,0"/>
                    <TextBlock Text="• Verde: nombre válido con números" TextWrapping="Wrap" FontSize="10"/>
                    <TextBlock Text="• Blanco: nombre válido sin números" TextWrapping="Wrap" FontSize="10"/>
                    <TextBlock Text="• Rojo: nombre inválido" TextWrapping="Wrap" FontSize="10"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
